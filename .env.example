# MindPulse Backend — Environment Variables
# Copy this file to .env and fill in your values

# ── App ──────────────────────────────
DEBUG=false
HOST=0.0.0.0
PORT=8000

# ── Security ─────────────────────────
SECRET_KEY=change-me-to-a-random-secret-string

# ── CORS (comma-separated origins) ───
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ── Database ──────────────────────────
# Leave MONGO_URI empty to use SQLite (default, no setup needed)
MONGO_URI=
DB_NAME=mindpulse

# ── Auth ─────────────────────────────
TOKEN_EXPIRE_H=72

# ── Analysis ──────────────────────────
MIN_TEXT_LENGTH=3
CRISIS_ALERT_EMAIL=
