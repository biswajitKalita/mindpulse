# MindPulse Frontend — Environment Variables
# Copy this file to .env and fill in your values
# .env is gitignored and will never be committed

# Backend URL (your Render deployment URL)
# Example: https://mindpulse-api.onrender.com
VITE_API_BASE_URL=http://localhost:8000

# Set to 'true' to use localStorage mock instead of real backend (dev only)
VITE_USE_MOCK=false
