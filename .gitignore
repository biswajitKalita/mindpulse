# Environment variables (NEVER commit — contains API keys & passwords)
.env
.env.local
.env.production

# Database files (SQLite)
*.db
*.sqlite
*.sqlite3

# ML model files — large binary files
# NOTE: small model files (<90MB) ARE committed for Render deployment
# Only exclude the huge ones that exceed GitHub's 100MB limit
*.h5
*.joblib
*.onnx
*.npy
*.npz
# Exclude only the 190MB goemotion model (too large for GitHub)
mindpulse/Models/goemotion_model.pkl

# Large training datasets & audio (too big for GitHub — use cloud storage)
mindpulse/Data/
*.wav
*.csv
*.tsv
*.mp3
*.mp4

# Jupyter Notebook checkpoints
.ipynb_checkpoints/
*.ipynb

# Logs
*.log
logs/

# OS files
.DS_Store
Thumbs.db

